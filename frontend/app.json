{
  "expo": {
    "name": "SLIIT KADE",
    "slug": "sliit-kade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uvs.sliitkade"
    },
    "android": {
      "package": "com.uvs.sliitkade",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCthZ7hWLztcZIqJiO1386-qxZmqH1jx2E"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "./plugins/withAndroidBuildFix",
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.283392568548-dummy"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7b8401d9-380a-4b07-aaa9-1f1e43e0f9b0"
      }
    }
  }
}
